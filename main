<body>
    <div class="main-layout">
        <div class="left-panel">
            <h1 class="page-title">怪物查询</h1>

            <div class="filter-section">
                <div class="filter-group">
                    <span class="filter-label">标签1：怪物类型</span>
                    <div class="filter-options" id="tag1Options">
                        <span class="filter-tag" data-tag="tag1" data-value="普通怪">普通怪</span>
                        <span class="filter-tag" data-tag="tag1" data-value="地方传奇/历经百战">地方传奇/历经百战</span>
                    </div>
                </div>

                <div class="filter-group">
                    <span class="filter-label">标签2：所属势力</span>
                    <div class="filter-options" id="tag2Options">
                        <span class="filter-tag" data-tag="tag2" data-value="元素生命">元素生命</span>
                        <span class="filter-tag" data-tag="tag2" data-value="丘丘部族">丘丘部族</span>
                        <span class="filter-tag" data-tag="tag2" data-value="深渊">深渊</span>
                        <span class="filter-tag" data-tag="tag2" data-value="愚人众">愚人众</span>
                        <span class="filter-tag" data-tag="tag2" data-value="其它人类势力">其它人类势力</span>
                        <span class="filter-tag" data-tag="tag2" data-value="自律机关">自律机关</span>
                        <span class="filter-tag" data-tag="tag2" data-value="异种魔兽">异种魔兽</span>
                    </div>
                </div>

                <div class="filter-group">
                    <span class="filter-label">标签3：登场版本</span>
                    <div class="filter-options" id="tag3Options">
                        <span class="filter-tag" data-tag="tag3" data-value="1.0">1.0</span>
                        <span class="filter-tag" data-tag="tag3" data-value="1.1">1.1</span>
                        <span class="filter-tag" data-tag="tag3" data-value="1.2">1.2</span>
                        <span class="filter-tag" data-tag="tag3" data-value="2.0">2.0</span>
                        <span class="filter-tag" data-tag="tag3" data-value="2.1">2.1</span>
                        <span class="filter-tag" data-tag="tag3" data-value="3.0">3.0</span>
                        <span class="filter-tag" data-tag="tag3" data-value="4.0">4.0</span>
                        <span class="filter-tag" data-tag="tag3" data-value="5.0">5.0</span>
                    </div>
                </div>

                <div class="filter-actions">
                    <button class="filter-btn primary" id="applyFilterBtn">应用筛选</button>
                    <button class="filter-btn" id="clearFilterBtn">清除全部筛选</button>
                </div>
            </div>

            <div class="monster-grid" id="monsterGrid"></div>
        </div>

        <div class="right-panel" id="rightPanel">
            <div class="detail-panel" id="detailPanel">
                <div class="detail-header">
                    <span class="detail-title" id="detailTitle">怪物详情</span>
                    <button class="detail-close" id="detailCloseBtn" aria-label="关闭">×</button>
                </div>
                <div class="detail-content" id="detailContent"></div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const tag1Options = document.getElementById('tag1Options');
            const tag2Options = document.getElementById('tag2Options');
            const tag3Options = document.getElementById('tag3Options');
            const applyFilterBtn = document.getElementById('applyFilterBtn');
            const clearFilterBtn = document.getElementById('clearFilterBtn');
            const monsterGrid = document.getElementById('monsterGrid');
            const detailPanel = document.getElementById('detailPanel');
            const detailTitle = document.getElementById('detailTitle');
            const detailContent = document.getElementById('detailContent');
            const detailCloseBtn = document.getElementById('detailCloseBtn');

            let selectedFilters = {
                tag1: null,
                tag2: null,
                tag3: null
            };

            let currentSelectedMonster = null;

            const monsters = [
                {
                    name: '飘浮灵',
                    tag1: '普通怪',
                    tag2: '元素生命',
                    tag3: '2.1',
                    detail: 'PFL'
                },
                {
                    name: '史莱姆',
                    tag1: '普通怪',
                    tag2: '元素生命',
                    tag3: '1.0',
                    detail: 'SLM'
                }
            ];

            function sortByVersion(monsterList) {
                return monsterList.sort((a, b) => {
                    const versionA = parseFloat(a.tag3);
                    const versionB = parseFloat(b.tag3);
                    return versionA - versionB;
                });
            }

            function renderMonsters(monsterList) {
                if (monsterList.length === 0) {
                    monsterGrid.innerHTML = '<div class="monster-empty">没有符合筛选条件的怪物</div>';
                    return;
                }

                const sorted = sortByVersion([...monsterList]);
                monsterGrid.innerHTML = sorted.map(monster => `
                    <div class="monster-card${currentSelectedMonster && currentSelectedMonster.name === monster.name ? ' selected' : ''}" data-name="${monster.name}">
                        <div>${monster.name}</div>
                        <div class="card-tags">
                            <span class="card-tag">${monster.tag1}</span>
                            <span class="card-tag">${monster.tag2}</span>
                            <span class="card-tag">v${monster.tag3}</span>
                        </div>
                    </div>
                `).join('');

                document.querySelectorAll('.monster-card').forEach(card => {
                    card.addEventListener('click', function() {
                        const name = this.dataset.name;
                        selectMonster(name);
                    });
                });
            }

            function selectMonster(name) {
                const monster = monsters.find(m => m.name === name);
                if (!monster) return;

                if (currentSelectedMonster && currentSelectedMonster.name === name) {
                    return;
                }

                if (currentSelectedMonster) {
                    detailPanel.classList.remove('active');
                    setTimeout(() => {
                        updateDetailPanel(monster);
                        detailPanel.classList.add('active');
                    }, 150);
                } else {
                    updateDetailPanel(monster);
                    detailPanel.classList.add('active');
                }

                currentSelectedMonster = monster;
                refreshCardSelection();
            }

            function updateDetailPanel(monster) {
                detailTitle.textContent = monster.name;
                detailContent.textContent = monster.detail;
            }

            function closeDetailPanel() {
                detailPanel.classList.remove('active');
                currentSelectedMonster = null;
                refreshCardSelection();
            }

            function refreshCardSelection() {
                document.querySelectorAll('.monster-card').forEach(card => {
                    const name = card.dataset.name;
                    if (currentSelectedMonster && currentSelectedMonster.name === name) {
                        card.classList.add('selected');
                    } else {
                        card.classList.remove('selected');
                    }
                });
            }

            function handleTagClick(e) {
                const tag = e.target.closest('.filter-tag');
                if (!tag) return;

                const tagGroup = tag.dataset.tag;
                const tagValue = tag.dataset.value;
                const parentGroup = tag.parentElement;

                if (selectedFilters[tagGroup] === tagValue) {
                    selectedFilters[tagGroup] = null;
                    parentGroup.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
                } else {
                    parentGroup.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
                    tag.classList.add('active');
                    selectedFilters[tagGroup] = tagValue;
                }
            }

            function applyFilter() {
                const activeFilterCount = (selectedFilters.tag1 ? 1 : 0) + 
                                         (selectedFilters.tag2 ? 1 : 0) + 
                                         (selectedFilters.tag3 ? 1 : 0);

                if (activeFilterCount === 0) {
                    renderMonsters(monsters);
                    return;
                }

                const filtered = monsters.filter(monster => {
                    if (selectedFilters.tag1 && monster.tag1 !== selectedFilters.tag1) return false;
                    if (selectedFilters.tag2 && monster.tag2 !== selectedFilters.tag2) return false;
                    if (selectedFilters.tag3 && monster.tag3 !== selectedFilters.tag3) return false;
                    return true;
                });

                renderMonsters(filtered);
            }

            function clearAllFilters() {
                selectedFilters = {
                    tag1: null,
                    tag2: null,
                    tag3: null
                };

                document.querySelectorAll('.filter-tag').forEach(tag => {
                    tag.classList.remove('active');
                });

                renderMonsters(monsters);
            }

            tag1Options.addEventListener('click', handleTagClick);
            tag2Options.addEventListener('click', handleTagClick);
            tag3Options.addEventListener('click', handleTagClick);

            applyFilterBtn.addEventListener('click', applyFilter);
            clearFilterBtn.addEventListener('click', clearAllFilters);

            detailCloseBtn.addEventListener('click', closeDetailPanel);

            renderMonsters(monsters);
        })();
    </script>
</body>
</html>
